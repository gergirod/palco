# Palco — variables de entorno
# Copiá a .env.local para dev. En Vercel: Project → Settings → Environment Variables.

# Supabase (proyecto "palco") — Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Solo para scripts/pipeline/briefings (NO commitear, NO poner en el front)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# GitHub Actions → resúmenes (scripts/send_briefs.py)
#   diario: cron 17:00 ART · usuarios con frecuencia "diario"
#   semanal: cron lunes 17:00 ART · usuarios con frecuencia "semanal"
#
# GitHub Actions → alertas (scripts/send_alerts.py)
#   al-toque: post-pipeline (repository_dispatch palco-pipeline-done)
#   crisis: incluida en alertas aunque el usuario elija otro modo
# RESEND_API_KEY=re_...
# RESEND_FROM=Palco <briefings@tudominio.com>
# BRIEF_RECIPIENTS=cliente@empresa.com
# ALERT_RECIPIENTS=cliente@empresa.com
# BRIEF_WATCHLIST=lionel-messi,javier-milei
# PALCO_DASHBOARD_URL=https://palco-pi.vercel.app/dashboard
